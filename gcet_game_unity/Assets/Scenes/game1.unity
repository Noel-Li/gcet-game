--- !u!114 &3500000202
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1166140797}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 35e65e4302661f84f8428024eb88eebc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Conversation
  steps:
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: tired
    panelStyle: 0
    text: "Excuse me! Excuse me! \u4F60\u662F\u90ED\u54C1\u7389\u5417\uFF1F (N\u01D0
      sh\xEC Gu\u014D P\u01D0ny\xF9 ma?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u54C1\u7389"
    expression: confused
    panelStyle: 0
    text: "\u5BF9\u5440\u3002\u4F60\u662F\u8C01\u5440\uFF1F (Du\xEC ya. N\u01D0 sh\xEC
      sh\xE9i ya?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u6211\u662F\u90ED\u5C0F\u6708\u3002 (W\u01D2 sh\xEC Gu\u014D Xi\u01CEoyu\xE8.)
      I think this is your book...?"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u54C1\u7389"
    expression: normal
    panelStyle: 0
    text: Yes, it is... How did you get it?
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: I'm from the future, and I got teleported back in time with this book in
      hand. It has taught me a lot.
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u54C1\u7389"
    expression: normal
    panelStyle: 0
    text: Ah... yes. It's a magic book that helps you learn Chinese.
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u54C1\u7389"
    expression: confused
    panelStyle: 0
    text: Wait, but how are you here?
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "I have a bracelet that apparently you made, but I accidentally broke it\u2014and
      the charms too."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u54C1\u7389"
    expression: normal
    panelStyle: 0
    text: Charms...? I believe I have just the thing for you.
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: excited
    panelStyle: 0
    text: Yes, that's exactly it! Thank you!
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u54C1\u7389"
    expression: normal
    panelStyle: 0
    text: I made it with the oasis water of Dunhuang, as well as crystals of azurite.
      Try casting a spell!
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: Okay...
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u6C34 (shu\u01D0) to cast the spell."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u6C34"
      targetStep: 13
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u6C34"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: excited
    panelStyle: 0
    text: It works! Thank you, thank you!
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  repeatSteps:
  - speakerName: "\u90ED\u54C1\u7389"
    expression: normal
    panelStyle: 0
    text: "Take care of the book\u2014and your new charm."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  speakerBackgrounds:
  - speakerName: "\u90ED\u5C0F\u6708"
