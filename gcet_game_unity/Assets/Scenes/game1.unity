--- !u!114 &368804119
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 368804118}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 35e65e4302661f84f8428024eb88eebc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Conversation
  steps:
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "Hi! Are you \u738B\u559C\u60A6 (W\xE1ng X\u01D0yu\xE8)?"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "\u5BF9\uFF0C\u6211\u662F\u3002Who are you? (Du\xEC, w\u01D2 sh\xEC.)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u6211\u662F\u90ED\u5C0F\u6708 (W\u01D2 sh\xEC Gu\u014D Xi\u01CEoyu\xE8).
      \u6211\u6709\u4E00\u4EF6\u4E8B\u60C5 (W\u01D2 y\u01D2u y\xED ji\xE0n sh\xECq\xEDng).
      I was told that you know where my... my grandma is, \u90ED\u54C1\u7389 (Gu\u014D
      P\u01D0ny\xF9)."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u4E8B (sh\xEC), meaning \u201Cthing.\u201D"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u4E8B"
      targetStep: 4
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u4E8B"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: <i>*Don't want them to get suspicious of me.*</i>
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "Woah! \u6211 (W\u01D2) never \u542C\u8BF4\u8FC7\u90ED\u54C1\u7389\u6709\u4E2A
      (t\u012Bng shu\u014Dgu\xF2 Gu\u014D P\u01D0ny\xF9 y\u01D2u g\xE8) granddaughter?"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "I haven't seen her in 2 days... \u4F46\u662F\u6211\u542C\u8BF4 (D\xE0nsh\xEC
      w\u01D2 t\u012Bng shu\u014D) she is going to be giving her stuff to the trader
      who passes by here."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "Fill in the blank: ___\u77E5\u9053\u5979\u5728\u54EA\u91CC\u5417\uFF1F"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u4F60"
      targetStep: 8
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u4F60"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u4F60\u77E5\u9053\u5979\u5728\u54EA\u91CC\u5417\uFF1F (N\u01D0 zh\u012Bd\xE0o
      t\u0101 z\xE0i n\u01CEl\u01D0 ma?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "\u6211\u6628\u5929\u770B\u5230\u5434\u53D4\u6768 (W\u01D2 zu\xF3ti\u0101n
      k\xE0n d\xE0o W\xFA Sh\u016By\xE1ng), who is our trader. He said he was meeting
      \u90ED\u54C1\u7389 (Gu\u014D P\u01D0ny\xF9) at the bridge across the river."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: panic
    panelStyle: 0
