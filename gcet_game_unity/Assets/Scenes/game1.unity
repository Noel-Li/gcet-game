--- !u!114 &200000026
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 200000020}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 35e65e4302661f84f8428024eb88eebc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Conversation
  steps:
  - speakerName: soldier
    expression: normal
    panelStyle: 0
    text: "Hello, are you \u5F20\u4E09 (Zh\u0101ng S\u0101n)?"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game voice
    expression: normal
    panelStyle: 1
    text: "Use the tracer to write the player's answer: \u4E0D"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u4E0D"
      targetStep: 2
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u4E0D"
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: normal
    panelStyle: 0
    text: "\u4E0D\u3002 (B\xF9.)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: normal
    panelStyle: 0
    text: "\u4F60\u53EB\u4EC0\u4E48\u540D\u5B57 (N\u01D0 ji\xE0o sh\xE9nme m\xEDngz\xEC)\uFF1F"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game voice
    expression: normal
    panelStyle: 1
    text: 'Select the translation for this:'
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: What is your name?
      targetStep: 9
      action: 0
      requiredTraceCount: 1
      traceCharacters: []
    - label: How are you?
      targetStep: 5
      action: 0
      requiredTraceCount: 1
      traceCharacters: []
    - label: Where are you from?
      targetStep: 7
      action: 0
      requiredTraceCount: 1
      traceCharacters: []
    useMultipleChoicePanel: 1
  - speakerName: player
    expression: normal
    panelStyle: 0
    text: "\u6211\u5F88\u597D\u3002 (W\u01D2 h\u011Bn h\u01CEo.)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: normal
    panelStyle: 0
    text: "I didn't ask how you are. I asked \u201C\u4F60\u53EB\u4EC0\u4E48\u540D\u5B57\uFF1F\u201D
      My name is \u674E\u6C85\u8BFA (L\u01D0 Yu\xE1nnu\xF2). \u4F60\u53EB\u4EC0\u4E48\u540D\u5B57
      (N\u01D0 ji\xE0o sh\xE9nme m\xEDngz\xEC)\uFF1F"
    action: 0
    nextStep: 4
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: normal
    panelStyle: 0
    text: "\u7F8E\u56FD\u3002 (M\u011Bigu\xF3.)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: normal
    panelStyle: 0
    text: "I didn't ask where you are from. I asked \u201C\u4F60\u53EB\u4EC0\u4E48\u540D\u5B57\uFF1F\u201D
      My name is \u674E\u6C85\u8BFA (L\u01D0 Yu\xE1nnu\xF2). \u4F60\u53EB\u4EC0\u4E48\u540D\u5B57
      (N\u01D0 ji\xE0o sh\xE9nme m\xEDngz\xEC)\uFF1F"
    action: 0
    nextStep: 4
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: normal
    panelStyle: 0
    text: "\u90ED\u5C0F\u6708\u3002 (Gu\u014D Xi\u01CEoyu\xE8.)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: normal
    panelStyle: 0
    text: "Hello, \u90ED\u5C0F\u6708 (Gu\u014D Xi\u01CEoyu\xE8). My name is \u674E\u6C85\u8BFA
      (L\u01D0 Yu\xE1nnu\xF2)."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: confused
    panelStyle: 0
    text: "Wait... did you say \u90ED (Gu\u014D)?"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game voice
    expression: normal
    panelStyle: 1
    text: "Trace \u5BF9 (Du\xEC) to answer \u201Cright.\u201D"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u5BF9"
      targetStep: 13
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u5BF9"
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: confused
    panelStyle: 0
    text: "\u5BF9...? (Du\xEC...?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: confused
    panelStyle: 0
    text: "Are you related to \u90ED\u54C1\u7389 (Gu\u014D P\u01D0ny\xF9)?"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: worried
    panelStyle: 0
    text: "*Hmm... that name sounds familiar. Wait\u2014that's the first person in
      my family line to have powers!*"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: excited
    panelStyle: 0
    text: Yes! I am. How did you know?
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: surprised
    panelStyle: 0
    text: "She is our local Artisan. \u5979\u505A\u7684 (T\u0101 zu\xF2 de) equipment
      \u662F\u6700\u597D\u7684 (sh\xEC zu\xEC h\u01CEo de). We all don't know how,
      but we don't ask questions."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game voice
    expression: normal
    panelStyle: 1
    text: "What does \u201C\u5979\u505A\u6700\u597D\u7684...\u201D mean?"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: He makes the best...
      targetStep: 19
      action: 0
      requiredTraceCount: 1
      traceCharacters: []
    - label: She makes the best...
      targetStep: 20
      action: 0
      requiredTraceCount: 1
      traceCharacters: []
    - label: She drinks the best...
      targetStep: 19
      action: 0
      requiredTraceCount: 1
      traceCharacters: []
    useMultipleChoicePanel: 1
  - speakerName: game voice
    expression: normal
    panelStyle: 1
    text: Wrong answer. Try again.
    action: 0
    nextStep: 18
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: confused
    panelStyle: 0
    text: Do you know where I can find her?
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: soldier
    expression: normal
    panelStyle: 0
    text: "She never stays \u540C\u4E00\u5730\u65B9 (t\xF3ng y\u012B d\xECf\u0101ng),
      but I'm sure \u738B\u559C\u60A6 (W\xE1ng X\u01D0yu\xE8) knows where she is.
      She sells her silk in town. You can \u95EE\u5979 (W\xE8n t\u0101). She is just
      up ahead. \u4E0D\u8981 (B\xFA y\xE0o) cause any trouble."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game voice
    expression: normal
    panelStyle: 1
    text: "Trace characters to remember important information from the conversation.
      Trace \u4E0D, \u8981, and \u95EE."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Start tracing \u4E0D, \u8981, and \u95EE"
      targetStep: 23
      action: 1
      requiredTraceCount: 3
      traceCharacters:
      - "\u4E0D"
      - "\u8981"
      - "\u95EE"
    useMultipleChoicePanel: 0
  - speakerName: player
    expression: excited
    panelStyle: 0
    text: "\u8C22\u8C22\uFF01 (Xi\xE8xie!)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  repeatSteps:
  - speakerName: soldier
    expression: normal
    panelStyle: 0
    text: "Did you find \u738B\u559C\u60A6\uFF1F"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
