    slotOffset: {x: 0, y: 0}
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: excited
    portrait: {fileID: 7377018004420343006, guid: aeeb714301957a540aa0c83917ba04b8, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    portrait: {fileID: -894294935112038360, guid: 4f9ee480d9cb34d4793d3f1a428f619b, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u738B\u559C\u60A6"
