--- !u!114 &368804119
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 368804118}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 35e65e4302661f84f8428024eb88eebc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Conversation
  steps:
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "Hi! Are you \u738B\u559C\u60A6 (W\xE1ng X\u01D0yu\xE8)?"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "\u5BF9\uFF0C\u6211\u662F\u3002Who are you? (Du\xEC, w\u01D2 sh\xEC.)"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u6211\u662F\u90ED\u5C0F\u6708 (W\u01D2 sh\xEC Gu\u014D Xi\u01CEoyu\xE8).
      \u6211\u6709\u4E00\u4EF6\u4E8B\u60C5 (W\u01D2 y\u01D2u y\xED ji\xE0n sh\xECq\xEDng).
      I was told that you know where my... my grandma is, \u90ED\u54C1\u7389 (Gu\u014D
      P\u01D0ny\xF9)."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u4E8B (sh\xEC), meaning \u201Cthing.\u201D"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u4E8B"
      targetStep: 4
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u4E8B"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: <i>*Don't want them to get suspicious of me.*</i>
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "Woah! \u6211 (W\u01D2) never \u542C\u8BF4\u8FC7\u90ED\u54C1\u7389\u6709\u4E2A
      (t\u012Bng shu\u014Dgu\xF2 Gu\u014D P\u01D0ny\xF9 y\u01D2u g\xE8) granddaughter?"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "I haven't seen her in 2 days... \u4F46\u662F\u6211\u542C\u8BF4 (D\xE0nsh\xEC
      w\u01D2 t\u012Bng shu\u014D) she is going to be giving her stuff to the trader
      who passes by here."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "Fill in the blank: ___\u77E5\u9053\u5979\u5728\u54EA\u91CC\u5417\uFF1F"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u4F60"
      targetStep: 8
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u4F60"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u4F60\u77E5\u9053\u5979\u5728\u54EA\u91CC\u5417\uFF1F (N\u01D0 zh\u012Bd\xE0o
      t\u0101 z\xE0i n\u01CEl\u01D0 ma?)"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    panelStyle: 0
    text: "\u6211\u6628\u5929\u770B\u5230\u5434\u53D4\u6768 (W\u01D2 zu\xF3ti\u0101n
      k\xE0n d\xE0o W\xFA Sh\u016By\xE1ng), who is our trader. He said he was meeting
      \u90ED\u54C1\u7389 (Gu\u014D P\u01D0ny\xF9) at the bridge across the river."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u738B\u559C\u60A6"
    expression: panic
    panelStyle: 0
    text: "Maybe if you hurry, you will be able to catch them. \u5F88\u591A\u522B\u4EBA
      (H\u011Bndu\u014D bi\xE9r\xE9n) will be there, so be careful."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u522B\u4EBA (bi\xE9r\xE9n), which means \u201Cother people.\u201D"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u522B and \u4EBA"
      targetStep: 12
      action: 1
      requiredTraceCount: 2
      traceCharacters:
      - "\u522B"
      - "\u4EBA"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: excited
    panelStyle: 0
    text: "\u8C22\u8C22\uFF01 (Xi\xE8xie!)"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: <i>Quick! Hurry to the bridge before you miss your chance!</i>
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  repeatSteps:
  - speakerName: "\u738B\u559C\u60A6"
    expression: panic
    panelStyle: 0
    text: "Hurry! \u5434\u53D4\u6768 is waiting at the bridge across the river."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  speakerBackgrounds:
  - speakerName: "\u90ED\u5C0F\u6708"
    background: {fileID: 5026058822647386680, guid: 90632d7d2df81e34cb10bd441244ebb5, type: 3}
  - speakerName: "\u738B\u559C\u60A6"
    background: {fileID: -731586538600574123, guid: 91a6ac330e5f95e46ace8caa9a4d98a5, type: 3}
  speakerPortraits:
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    portrait: {fileID: 730228752406266095, guid: 305d640885e771745b7d46f9674b79ac, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: excited
    portrait: {fileID: -2300303421564334034, guid: d8c44b0e2fadca94fac7128d6791a7f4, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u738B\u559C\u60A6"
    expression: normal
    portrait: {fileID: -894294935112038360, guid: 4f9ee480d9cb34d4793d3f1a428f619b, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u738B\u559C\u60A6"
    expression: panic
    portrait: {fileID: -1511221300618825116, guid: 3d8e5a41933d2744389090b1d804b71b, type: 3}
    slotOffset: {x: 0, y: 0}
  gameVoiceBackground: {fileID: 8702785369876850875, guid: 6183e110186ac8a42bad440dacedf15a, type: 3}
  multipleChoiceBackground: {fileID: -9018818332010216090, guid: dd1d2b4546a5cb34a817cf814d3cecf5, type: 3}
