--- !u!114 &151484822
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 151484821}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 35e65e4302661f84f8428024eb88eebc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Conversation
  steps:
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: tired
    panelStyle: 0
    text: "\u4F60\u7684\u540D\u5B57\u662F\u90ED\u54C1\u7389\u5417\uFF1F (N\u01D0
      de m\xEDngz\xEC sh\xEC Gu\u014D P\u01D0ny\xF9 ma?)"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u7684 (de), meaning \u201Cof.\u201D"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u7684"
      targetStep: 2
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u7684"
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: stern
    panelStyle: 0
    text: "\u4E0D\u662F\u3002\u4F60\u662F\u8C01\uFF1F (B\xF9 sh\xEC. N\u01D0 sh\xEC
      sh\xE9i?)"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: tired
    panelStyle: 0
    text: "\u6211\u662F\u90ED\u5C0F\u6708\u3002 (W\u01D2 sh\xEC Gu\u014D Xi\u01CEoyu\xE8.)
      Then are you \u5434\u53D4\u6768\u5417\uFF1F (W\xFA Sh\u016By\xE1ng ma?)"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: stern
    panelStyle: 0
    text: "\u6211\u662F\u5440\uFF01 How do you \u77E5\u9053\u5440\uFF1F (N\u01D0
      z\u011Bnme zh\u012Bd\xE0o ya?)"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u738B\u559C\u60A6 (W\xE1ng X\u01D0yu\xE8) said you would be meeting \u90ED\u54C1\u7389
      (Gu\u014D P\u01D0ny\xF9)."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: shock
    panelStyle: 0
    text: "Oh yes, I did! But that was an hour ago. I'm not sure where she is. \u6211\u5F88\u559C\u6B22\u5979\u7684
      (W\u01D2 h\u011Bn x\u01D0hu\u0101n t\u0101 de) materials."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u559C\u6B22 (x\u01D0hu\u0101n), meaning \u201Clike.\u201D"
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u559C and \u6B22"
      targetStep: 8
      action: 1
      requiredTraceCount: 2
      traceCharacters:
      - "\u559C"
      - "\u6B22"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: Do you know where I can find her?
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: normal
    panelStyle: 0
    text: "Not sure... But maybe look in that book? I recognize the design; it has
      an inscription from \u90ED\u54C1\u7389 (Gu\u014D P\u01D0ny\xF9) on it."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u8C22\u8C22\uFF01 (Xi\xE8xie!)"
    panelIllustration: {fileID: 0}
    action: 3
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game voice
    expression: normal
    panelStyle: 1
    text: "\u4E0D\u8981\u95EE\u522B\u4EBA\u4F60\u4E0D\u559C\u6B22\u7684\u4E8B\nDon't
      ask others about things you don't like."
    panelIllustration: {fileID: 0}
    action: 1
    nextStep: 12
    requiredTraceCount: 11
    traceCharacters:
    - "\u4E0D"
    - "\u8981"
    - "\u95EE"
    - "\u522B"
    - "\u4EBA"
    - "\u4F60"
    - "\u4E0D"
    - "\u559C"
    - "\u6B22"
    - "\u7684"
    - "\u4E8B"
    choices: []
    useMultipleChoicePanel: 0
  repeatSteps:
  - speakerName: "\u5434\u53D4\u6768"
    expression: normal
    panelStyle: 0
    text: "Maybe look in that book. I recognize \u90ED\u54C1\u7389's inscription
      on it."
    panelIllustration: {fileID: 0}
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  speakerBackgrounds:
  - speakerName: "\u90ED\u5C0F\u6708"
