--- !u!114 &151484822
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 151484821}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 35e65e4302661f84f8428024eb88eebc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Conversation
  steps:
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: tired
    panelStyle: 0
    text: "\u4F60\u7684\u540D\u5B57\u662F\u90ED\u54C1\u7389\u5417\uFF1F (N\u01D0
      de m\xEDngz\xEC sh\xEC Gu\u014D P\u01D0ny\xF9 ma?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u7684 (de), meaning \u201Cof.\u201D"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u7684"
      targetStep: 2
      action: 1
      requiredTraceCount: 1
      traceCharacters:
      - "\u7684"
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: stern
    panelStyle: 0
    text: "\u4E0D\u662F\u3002\u4F60\u662F\u8C01\uFF1F (B\xF9 sh\xEC. N\u01D0 sh\xEC
      sh\xE9i?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: tired
    panelStyle: 0
    text: "\u6211\u662F\u90ED\u5C0F\u6708\u3002 (W\u01D2 sh\xEC Gu\u014D Xi\u01CEoyu\xE8.)
      Then are you \u5434\u53D4\u6768\u5417\uFF1F (W\xFA Sh\u016By\xE1ng ma?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: stern
    panelStyle: 0
    text: "\u6211\u662F\u5440\uFF01 How do you \u77E5\u9053\u5440\uFF1F (N\u01D0
      z\u011Bnme zh\u012Bd\xE0o ya?)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u738B\u559C\u60A6 (W\xE1ng X\u01D0yu\xE8) said you would be meeting \u90ED\u54C1\u7389
      (Gu\u014D P\u01D0ny\xF9)."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: shock
    panelStyle: 0
    text: "Oh yes, I did! But that was an hour ago. I'm not sure where she is. \u6211\u5F88\u559C\u6B22\u5979\u7684
      materials."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: game
    expression: normal
    panelStyle: 1
    text: "Trace \u559C\u6B22 (x\u01D0hu\u0101n), meaning \u201Clike.\u201D"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices:
    - label: "Trace \u559C and \u6B22"
      targetStep: 8
      action: 1
      requiredTraceCount: 2
      traceCharacters:
      - "\u559C"
      - "\u6B22"
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: Do you know where I can find her?
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u5434\u53D4\u6768"
    expression: normal
    panelStyle: 0
    text: "Not sure... But maybe look in that book? I recognize the design; it has
      an inscription from \u90ED\u54C1\u7389 (Gu\u014D P\u01D0ny\xF9) on it."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    panelStyle: 0
    text: "\u8C22\u8C22\uFF01 (Xi\xE8xie!)"
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  repeatSteps:
  - speakerName: "\u5434\u53D4\u6768"
    expression: normal
    panelStyle: 0
    text: "Maybe look in that book. I recognize \u90ED\u54C1\u7389's inscription
      on it."
    action: 0
    nextStep: -1
    requiredTraceCount: 1
    traceCharacters: []
    choices: []
    useMultipleChoicePanel: 0
  speakerBackgrounds:
  - speakerName: "\u90ED\u5C0F\u6708"
    background: {fileID: 5026058822647386680, guid: 90632d7d2df81e34cb10bd441244ebb5, type: 3}
  - speakerName: "\u5434\u53D4\u6768"
    background: {fileID: 2275792330239745679, guid: 8a61a6c8b3f2bc24f9aac0a2c737ed7f, type: 3}
  speakerPortraits:
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: normal
    portrait: {fileID: 367173573683222419, guid: 6eafc250f344d7848bb41726d712aa81, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u90ED\u5C0F\u6708"
    expression: tired
    portrait: {fileID: 5487685175929054760, guid: ee8b35da6107dba4396efb88c261acfc, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u5434\u53D4\u6768"
    expression: normal
    portrait: {fileID: 5386588618949567342, guid: 7d379ae46fb7cbe46b11954216a0f617, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u5434\u53D4\u6768"
    expression: stern
    portrait: {fileID: -3353088238712625599, guid: 28b1ef8eed575eb438cc81cadfa36e2a, type: 3}
    slotOffset: {x: 0, y: 0}
  - speakerName: "\u5434\u53D4\u6768"
    expression: shock
    portrait: {fileID: 1988131225986853932, guid: d94c3841922951e41a1cb4fb654e475a, type: 3}
    slotOffset: {x: 0, y: 0}
